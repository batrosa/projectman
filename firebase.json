{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "firestore": {
      "port": 8080
    }
  },
  "hosting": {
    "public": "firebase-hosting",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/google-auth.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, max-age=0"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'none'; script-src 'self' https://accounts.google.com; style-src 'self'; img-src data: https://*.gstatic.com https://*.googleusercontent.com; frame-src https://accounts.google.com; connect-src https://accounts.google.com; base-uri 'none'; form-action 'none'; frame-ancestors 'none'"
          },
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "unsafe-none"
          },
          {
            "key": "Referrer-Policy",
            "value": "no-referrer"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          }
        ]
      }
    ]
  }
}
