# Copy to .env.local for local server work. Never commit real values.

# Required: Firebase Admin SDK. Keep the complete service-account JSON on one
# line; encode private-key line breaks as \n.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"replace-me","private_key":"-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@example.iam.gserviceaccount.com"}

# Required: private Cloudinary uploads/downloads. API_SECRET is server-only.
# The Cloudinary account must contain the signed authenticated preset
# projectman_private used by lib/cloudinary-files.js.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret

# Required for Telegram login/linking and notifications.
TELEGRAM_BOT_TOKEN=123456789:replace-with-bot-token
TELEGRAM_BOT_USERNAME=projectman_notify_bot
TELEGRAM_WEBHOOK_SECRET=replace-with-random-webhook-secret

# Required for Vercel Cron and .github/workflows/agent-monitor.yml. Use the
# same random value in Vercel and GitHub Actions secret CRON_SECRET.
CRON_SECRET=replace-with-random-cron-secret

# Required for AI features. Models are a comma/newline-separated priority
# list; the application appends its built-in fallbacks. Timeout: 3000-60000 ms.
OPENROUTER_API_KEY=sk-or-v1-replace-me
CHAT_AGENT_MODELS=openai/gpt-oss-120b,openai/gpt-oss-20b
OPENROUTER_TIMEOUT_MS=9000

# Public canonical HTTPS origin used in Telegram deep links and email buttons.
APP_BASE_URL=https://projectman.online

# Optional: Resend email notifications. Both values are required to enable
# email delivery; the sender domain must have valid SPF/DKIM records.
RESEND_API_KEY=re_replace-me
EMAIL_FROM=ProjectSfera <notifications@example.com>

# Optional operations override. Default is 45000 ms; normally leave unset.
AGENT_MONITOR_BUDGET_MS=45000

# Legacy compatibility only: not read by the current server runtime. Firebase
# Web API keys are public client identifiers, not service-account secrets.
FIREBASE_WEB_API_KEY=replace-with-firebase-web-api-key
