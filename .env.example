# Email-уведомления для пользователей с authProvider=google.com.
# Создайте API key в Resend и подтвердите домен отправителя (SPF + DKIM).
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=ProjectMan <notifications@updates.example.com>
APP_BASE_URL=https://projectman.online

# Firebase Admin SDK (JSON service-account object on one line).
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FIREBASE_WEB_API_KEY=AIza...

# Private Cloudinary server credentials. CLOUDINARY_API_SECRET must never be
# exposed in browser/iOS code. projectman_private is a signed authenticated preset.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_server_api_key
CLOUDINARY_API_SECRET=your_server_api_secret

# AI, Telegram and scheduled/webhook authentication.
OPENROUTER_API_KEY=sk-or-v1-...
TELEGRAM_BOT_TOKEN=123456:...
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-secret
CRON_SECRET=replace-with-a-random-secret
