    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@vercel/functions": "^3.7.5",
    "cloudinary": "2.10.0",
    "fflate": "^0.8.3",
    "firebase-admin": "13.5.0",
    "unpdf": "^1.6.2"
  }
}
