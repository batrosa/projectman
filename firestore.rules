rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Функция: Проверка, что пользователь Админ
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Функция: Проверка, что пользователь не меняет защищённые поля — роль,
    // доступы, организация, игровые счётчики (XP/уровень/статистика) И
    // telegramChatId. XP теперь начисляется только сервером (api/award-xp через
    // Admin SDK, в обход правил). telegramChatId привязывается только сервером в
    // ходе входа через Telegram-бота (api/telegram-auth, api/webhook,
    // lib/telegram-user) и используется в api/notify-telegram для маршрутизации
    // уведомлений (where('telegramChatId','==',...)) — если бы клиент мог его
    // писать, любой авторизованный мог бы привязать произвольный chatId и
    // релеить сообщения на чужой Telegram (обход изоляции по организации).
    // Клиент эти поля не пишет вообще, поэтому замок ничего не ломает.
    function notUpdatingRestrictedFields() {
      return (!request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role', 'allowedProjects', 'organizationId', 'orgRole',
        'totalXP', 'level', 'completedTasksCount', 'onTimeTasksCount', 'noRevisionTasksCount',
        'telegramId', 'telegramChatId', 'telegramUsername', 'telegramLinkedAt',
        'email', 'emailVerified', 'authProvider'
      ]));
    }

    // NOTE: self-service org creation (isSelfServiceOrgCreate /
    // isSelfServiceOrgCreateAtDocCreation / wasNotYetInOrg) was REMOVED.
    // Creating an organization is server-only now (api/org 'create', Admin SDK):
    // it generates a unique inviteCode, sets membersCount/plan/settings, and
    // assigns the owner's organizationId+orgRole server-side. The client no
    // longer writes org membership itself, so the client can't self-grant
    // orgRole:'owner' or fabricate an organizations doc.

    // Функция: Проверка прав на проект
    function canViewProject(projectId) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      // A member with no explicit allow-list sees ALL projects by default;
      // access is narrowed only when an admin sets allowedProjects. The
      // !('allowedProjects' in userData) guard covers freshly joined members
      // whose document has no allowedProjects field yet.
      return !('allowedProjects' in userData)
        || userData.allowedProjects == null
        || userData.allowedProjects.size() == 0
        || projectId in userData.allowedProjects;
    }

    // Функция: Проверка роли пользователя именно в указанной организации
    function hasOrgRole(orgId, roles) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null
        && orgId != null
        && userData.organizationId == orgId
        && userData.orgRole in roles;
    }

    // Организация текущего пользователя (или null).
    function myOrgId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId;
    }

    // Пользователь состоит в организации orgId (любая роль). Нужно для того,
    // чтобы чтение проектов/задач/файлов/календаря было СТРОГО в рамках своей
    // организации — иначе любой авторизованный мог читать данные чужой орг.
    function isOrgMember(orgId) {
      return request.auth != null && orgId != null && myOrgId() == orgId;
    }

    function projectBelongsToOrg(projectId, orgId) {
      return projectId != null
        && orgId != null
        && exists(/databases/$(database)/documents/projects/$(projectId))
        && get(/databases/$(database)/documents/projects/$(projectId)).data.organizationId == orgId;
    }

    function projectMissing(projectId) {
      return projectId == null
        || !exists(/databases/$(database)/documents/projects/$(projectId));
    }

    function hasProjectOrgRole(projectId, roles) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null
        && userData.orgRole in roles
        && projectBelongsToOrg(projectId, userData.organizationId);
    }

    // Кто может УПРАВЛЯТЬ данными проекта (создавать/править/удалять задачи и
    // файлы): владелец/админ организации проекта — всегда; модератор — ТОЛЬКО
    // если проект ему доступен (allowedProjects). Ключуется по организации
    // ПРОЕКТА (projectBelongsToOrg), а не по полю задачи, чтобы работать и для
    // задач без organizationId. Так ограничение проектов из панели доступа
    // применяется и к модератору, а не только в UI.
    function canManageProject(projectId) {
      return hasProjectOrgRole(projectId, ['owner', 'admin'])
        || (hasProjectOrgRole(projectId, ['moderator']) && canViewProject(projectId));
    }

    function canReaderWorkOnTask() {
      return request.auth != null
        && taskBelongsToMyOrgByProjectOrOrphanOrg()
        && canViewProject(resource.data.projectId)
        && (!('assigneeIds' in resource.data)
            || resource.data.assigneeIds.size() == 0
            || resource.data.assigneeIds.hasAny([request.auth.uid]));
    }

    function taskBelongsToMyOrgByProjectOrOrphanOrg() {
      return projectBelongsToOrg(resource.data.projectId, myOrgId())
        || (projectMissing(resource.data.projectId) && isOrgMember(resource.data.organizationId));
    }

    function requestTaskOrgMatchesCurrentOrg() {
      return !('organizationId' in request.resource.data)
        || request.resource.data.organizationId == myOrgId();
    }

    function requestTaskOrgPreservedOrCurrent() {
      return (('organizationId' in resource.data)
          && request.resource.data.organizationId == resource.data.organizationId)
        || (!('organizationId' in resource.data)
          && requestTaskOrgMatchesCurrentOrg());
    }

    // A private task has one canonical audience derived from its business
    // roles. Keeping viewerIds derived (rather than client-defined) prevents a
    // creator from silently granting access to an unrelated account or
    // forgetting one of the assignees/co-creators.
    function hasValidPrivateTaskAudience(data) {
      return data.isPrivate == true
        && data.createdByUid is string
        && data.createdByUid.size() > 0
        && data.assigneeIds is list
        && data.coCreatorIds is list
        && data.viewerIds is list
        && data.viewerIds.size() <= 100
        && data.viewerIds.toSet()
          == data.assigneeIds.concat(data.coCreatorIds).concat([data.createdByUid]).toSet();
    }

    function isPrivateTaskParticipant(data) {
      return request.auth != null
        && request.auth.uid in data.viewerIds;
    }

    // (isOrgUserStatsUpdate removed — XP/stats are server-only now; see api/award-xp.)

    // Коллекция Users
    match /users/{userId} {
      // Читать может: сам пользователь свой док; участник ТОЙ ЖЕ организации
      // (нужно для списка исполнителей/коллег); Админ. Раньше read был открыт
      // ВСЕМ авторизованным — это давало межарендную утечку (email,
      // telegramChatId, статистика, orgRole всех пользователей всех организаций).
      // Клиент и так грузит только свою организацию (setupRealtimeListeners
      // скоупит запрос по organizationId), поэтому легитимные списки не меняются.
      allow read: if request.auth != null && (
        request.auth.uid == userId
        || isAdmin()
        || (
          ('organizationId' in resource.data)
          && resource.data.organizationId != null
          && resource.data.organizationId == myOrgId()
        )
      );
      
      // Создавать профиль может только сам пользователь при регистрации (роль
      // 'reader' или отсутствует, БЕЗ орг-полей). Создание организации теперь
      // серверное (api/org), поэтому org-поля при клиентском создании профиля
      // запрещены — это закрывает само-присвоение orgRole:'owner' на «свежем»
      // документе users.
      allow create: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['organizationId', 'orgRole'])
        && !request.resource.data.keys().hasAny([
          'email', 'emailVerified', 'authProvider',
          'telegramId', 'telegramChatId', 'telegramUsername', 'telegramLinkedAt'
        ])
        && (!request.resource.data.keys().hasAll(['role']) || request.resource.data.role == 'reader');
      
      // Обновлять: сам пользователь (но БЕЗ защищённых полей —
      // notUpdatingRestrictedFields) ИЛИ глобальный админ. Все оргоперации и
      // управление ролями/allowedProjects идут только через server-side API
      // (api/org, api/join-org) с Admin SDK. Прямой клиентский manager-update
      // убран: он расходился с серверными ограничениями для admin/admin.
      allow update: if (request.auth != null && request.auth.uid == userId
                         && notUpdatingRestrictedFields())
                    || isAdmin();

      // Удалять: Только Админ
      allow delete: if isAdmin();

      // Push-токены устройств (roadmap Этап 3): iOS/Android пишут сюда свой
      // FCM-токен, сервер (lib/push-send.js, Admin SDK) читает их для
      // отправки. Доступ строго владельцу аккаунта — токен чужого устройства
      // нельзя ни прочитать (перехват уведомлений), ни перезаписать.
      match /devices/{deviceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Реестр членств в организациях. Пишется только сервером (api/org,
    // api/join-org), читается участниками активной организации для списка
    // сотрудников, ролей и доступа к проектам в multi-org сценарии.
    match /organizationMemberships/{membershipId} {
      allow read: if request.auth != null
        && ('organizationId' in resource.data)
        && isOrgMember(resource.data.organizationId);
      allow create, update, delete: if isAdmin();
    }

    // Функция: Пользователь — владелец организации (по своему orgRole) или админ организации
    function isOrgOwnerOrAdmin(orgId) {
      return hasOrgRole(orgId, ['owner', 'admin']);
    }

    // Коллекция Organizations
    match /organizations/{orgId} {
      // Читать (get одного документа) может только участник этой организации —
      // getOrganization() читает лишь СВОЮ организацию. Листинг/запросы по
      // коллекции запрещены полностью: это закрывает enumeration инвайт-кодов
      // (раньше любой авторизованный мог получить список всех организаций и их
      // inviteCode). Превью по коду, создание и смена кода теперь только
      // серверные (api/org, api/join-org) через Admin SDK.
      allow get: if isOrgOwnerOrAdmin(orgId) || isAdmin();
      allow list: if false;
      // Создание организации — ТОЛЬКО сервер (api/org 'create', Admin SDK): он
      // генерирует уникальный inviteCode, выставляет membersCount/plan/settings
      // и назначает владельца. Клиентский create раньше позволял сфабриковать
      // орг-документ с любым inviteCode/plan/membersCount в обход этой логики.
      allow create: if false;
      // Обновлять: владелец/админ организации, БЕЗ переназначения ownerId
      // («тихий» захват) и ТОЛЬКО поле name. Всё остальное — server-only через
      // Admin SDK (api/org, api/join-org): inviteCode, plan, membersCount,
      // createdAt И settings (settings.maxUsers задаётся при создании орг и
      // менять его с клиента нельзя — иначе владелец обходит собственный лимит
      // участников; единственный клиентский писатель settings, updateOrgLimit,
      // мёртв и не вызывается).
      allow update: if request.auth != null
        && (resource.data.ownerId == request.auth.uid || isOrgOwnerOrAdmin(orgId))
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name']);
      // Удалять — ТОЛЬКО сервер (api/org 'deleteOrg', Admin SDK): удаление
      // каскадит проекты/задачи/файлы и очищает участников. Клиентское удаление
      // org-документа напрямую оставляло бы всё это сиротами, поэтому запрещено.
      allow delete: if false;
    }

    // Коллекция Projects
    match /projects/{projectId} {
      // Read: any member of the project's organization. Per-project visibility
      // (allowedProjects) is applied CLIENT-SIDE (getFilteredProjects hides the
      // sidebar entry) rather than here, because the client loads projects with
      // one broad `where(organizationId==)` query and Firestore fails the WHOLE
      // query if any matched doc is unreadable — so a per-doc canViewProject
      // check here made a restricted member see ZERO projects. The sensitive
      // content (a project's TASKS and FILES) stays gated by canViewProject in
      // their own rules below, so a member still cannot read a forbidden
      // project's tasks/files; only the project's name/deadline metadata is
      // org-readable.
      allow read: if isAdmin()
        || isOrgMember(resource.data.organizationId);
      allow create: if isAdmin() || hasOrgRole(request.resource.data.organizationId, ['owner', 'admin']);
      allow update: if isAdmin()
        || (hasOrgRole(resource.data.organizationId, ['owner', 'admin'])
            && request.resource.data.organizationId == resource.data.organizationId);
      allow delete: if isAdmin() || hasOrgRole(resource.data.organizationId, ['owner', 'admin']);
    }

    // Коллекция Tasks
    match /tasks/{taskId} {
      // Чтение: Админ или если есть доступ к проекту (тут сложно проверить проект без лишнего get, 
      // но мы проверим через поле projectId в самой задаче)
      // Read: managers by org OR by the project's org (hasProjectOrgRole). A
      // plain member (employee/reader) may read a task if they can view its
      // PROJECT and that project is in their org. We check the PROJECT's org
      // (projectBelongsToOrg), not the task's own organizationId, because some
      // tasks may lack/have-stale organizationId — keying off the task field
      // made the whole per-project query fail for a reader while it worked for a
      // moderator (who reads via the project). The task-org branch is kept too
      // for orphan tasks whose project was deleted.
      // Read: owner/admin of the task's org (or the project's org) see everything;
      // moderators/employees/readers only tasks of a project they can view
      // (allowedProjects) — so the access panel restricts moderators too.
      allow read: if isAdmin()
        || hasProjectOrgRole(resource.data.projectId, ['owner', 'admin'])
        || (projectMissing(resource.data.projectId) && hasOrgRole(resource.data.organizationId, ['owner', 'admin']))
        || (taskBelongsToMyOrgByProjectOrOrphanOrg() && canViewProject(resource.data.projectId));

      // Запись:
      // - Менеджер проекта (owner/admin, moderator с доступом) — любые задачи.
      // - ИСПОЛНИТЕЛЬ (employee) создаёт задачи в доступных проектах и
      //   получает права постановщика на СОЗДАННЫЕ ИМ задачи: полный update
      //   и delete (см. ветки createdByUid/coCreatorIds ниже). createdByUid
      //   при создании обязан равняться auth.uid — владение не подделать.
      // - Доп. постановщик (coCreatorIds) — те же права на эту задачу.
      // - Reader — только чтение и движение статуса своей назначенной задачи.
      allow create: if isAdmin()
        || (canManageProject(request.resource.data.projectId) && requestTaskOrgMatchesCurrentOrg())
        || (request.auth != null
            && hasOrgRole(request.resource.data.organizationId, ['owner', 'admin', 'moderator', 'employee'])
            && canViewProject(request.resource.data.projectId)
            && requestTaskOrgMatchesCurrentOrg()
            && request.resource.data.createdByUid == request.auth.uid);
      allow delete: if isAdmin() || canManageProject(resource.data.projectId)
        || (request.auth != null
            && taskBelongsToMyOrgByProjectOrOrphanOrg()
            && (resource.data.createdByUid == request.auth.uid
                || (resource.data.coCreatorIds is list && request.auth.uid in resource.data.coCreatorIds)));
      allow update: if isAdmin()
        || (canManageProject(resource.data.projectId)
            && request.resource.data.projectId == resource.data.projectId
            && requestTaskOrgPreservedOrCurrent())
        // Создатель задачи или доп. постановщик: полное редактирование СВОЕЙ
        // задачи (название, описание, исполнители, сроки, статусы, принятие,
        // доработка) — но без передачи владения и переноса между проектами.
        || (request.auth != null
            && (resource.data.createdByUid == request.auth.uid
                || (resource.data.coCreatorIds is list && request.auth.uid in resource.data.coCreatorIds))
            && request.resource.data.projectId == resource.data.projectId
            && requestTaskOrgPreservedOrCurrent()
            && request.resource.data.createdByUid == resource.data.createdByUid)
        || (request.auth != null
            && canReaderWorkOnTask()
            && request.resource.data.projectId == resource.data.projectId
            && request.resource.data.status == 'in-progress'
            // The task must ALREADY be in-progress — a reader can't reopen a
            // done/archived task by writing status back to 'in-progress'.
            && resource.data.status == 'in-progress'
            && request.resource.data.subStatus in ['in_work', 'completed']
            // No skipping the flow: can't jump straight from 'assigned' to
            // 'completed' (must pass through 'in_work' / "Взять в работу").
            && !(resource.data.subStatus == 'assigned' && request.resource.data.subStatus == 'completed')
            // Completing REQUIRES a proof list that is non-empty AND bounded.
            // The UI mandates a comment + 1..3 files (submitCompletionProof); the
            // count cap stops a direct-SDK write from stuffing an unbounded array.
            // Per-element URL/type/size validation isn't expressible in Firestore
            // rules (no list iteration) — that stays at upload time
            // (api/project-files) and in the render-side sanitizer.
            && (request.resource.data.subStatus != 'completed'
                || (request.resource.data.completionProofs is list
                    && request.resource.data.completionProofs.size() > 0
                    && request.resource.data.completionProofs.size() <= 10))
            // Bound attachments too (a reader may set them in in_work/completed).
            && (!('attachments' in request.resource.data)
                || !(request.resource.data.attachments is list)
                || request.resource.data.attachments.size() <= 20)
            // No backdating: on completion the client writes serverTimestamp(),
            // which the emulator/server resolves to request.time. A direct-SDK
            // write with an arbitrary/backdated completedAt is rejected, so it
            // can't forge an on-time completion (wasOnTime → on-time XP bonus).
            && (request.resource.data.subStatus != 'completed'
                || request.resource.data.completedAt == request.time)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status',
              'assigneeCompleted',
              'reminderSent',
              'subStatus',
              'attachments',
              'takenToWorkAt',
              'takenToWorkBy',
              'completedAt',
              'completionComment',
              'completionProof',
              'completionProofs',
              'completedBy',
              'revisionReason',
              'revisionReturnedBy',
              'revisionReturnedAt',
              'archivedAt',
              'archivedBy'
            ]))
        // Доп. постановщик (uid в coCreatorIds) — независимо от орг-роли —
        // может ТОЛЬКО принять задачу с проверки (completed → done/архив) или
        // вернуть её на доработку (completed → in_work + причина). Наборы
        // полей зафиксированы под updateTaskSubStatus('done'/'in_work'), так
        // что переписать содержание задачи или чужие поля этот carve-out не
        // позволяет. coCreatorIds сам защищён: его нет ни в одном hasOnly.
        || (request.auth != null
            && resource.data.coCreatorIds is list
            && request.auth.uid in resource.data.coCreatorIds
            && request.resource.data.projectId == resource.data.projectId
            && resource.data.status == 'in-progress'
            && resource.data.subStatus == 'completed'
            && (
              // Принять: completed → done (архив)
              (request.resource.data.status == 'done'
                && request.resource.data.subStatus == 'completed'
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  'status', 'subStatus', 'archivedAt', 'archivedBy',
                  'completedOnTime', 'xpAwarded', 'assigneeCompleted'
                ]))
              // На доработку: completed → in_work + причина возврата
              || (request.resource.data.status == 'in-progress'
                && request.resource.data.subStatus == 'in_work'
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  'status', 'subStatus', 'takenToWorkAt', 'takenToWorkBy',
                  'completedAt', 'completionComment', 'completionProof',
                  'completionProofs', 'completedBy', 'archivedAt', 'archivedBy',
                  'revisionReason', 'revisionReturnedBy', 'revisionReturnedAt',
                  'wasReturned', 'assigneeCompleted'
                ]))
            ));
    }

    // Private tasks live separately so existing broad queries against `tasks`
    // remain valid for old web/iOS releases. Firestore rules are not filters:
    // mixing public and participant-only documents in one collection would
    // make those broad queries fail entirely (or require insecure broad read).
    match /privateTasks/{taskId} {
      // Organization owner is the explicit oversight exception. Admins,
      // moderators and employees still need to be task participants.
      allow read: if hasOrgRole(resource.data.organizationId, ['owner'])
        || (isPrivateTaskParticipant(resource.data)
            && isOrgMember(resource.data.organizationId));

      // Client-created private tasks must identify the authenticated creator
      // and store the exact derived audience.
      allow create: if request.auth != null
        && request.resource.data.createdByUid == request.auth.uid
        && hasValidPrivateTaskAudience(request.resource.data)
        && canManageProject(request.resource.data.projectId)
        && requestTaskOrgMatchesCurrentOrg();

      // The organization owner keeps the oversight exception; any other
      // manager must also be an explicit task participant.
      allow delete: if hasOrgRole(resource.data.organizationId, ['owner'])
        || (isPrivateTaskParticipant(resource.data)
            && canManageProject(resource.data.projectId));

      allow update: if (hasOrgRole(resource.data.organizationId, ['owner'])
          && request.resource.data.organizationId == resource.data.organizationId
          && request.resource.data.projectId == resource.data.projectId
          && request.resource.data.createdByUid == resource.data.createdByUid
          && hasValidPrivateTaskAudience(request.resource.data))
        || (
          isPrivateTaskParticipant(resource.data)
          && isPrivateTaskParticipant(request.resource.data)
          && hasValidPrivateTaskAudience(request.resource.data)
          && request.resource.data.createdByUid == resource.data.createdByUid
          && request.resource.data.projectId == resource.data.projectId
          && requestTaskOrgPreservedOrCurrent()
          && canManageProject(resource.data.projectId)
        )
        || (request.auth != null
            && isPrivateTaskParticipant(resource.data)
            && canReaderWorkOnTask()
            && request.resource.data.projectId == resource.data.projectId
            && request.resource.data.status == 'in-progress'
            && resource.data.status == 'in-progress'
            && request.resource.data.subStatus in ['in_work', 'completed']
            && !(resource.data.subStatus == 'assigned' && request.resource.data.subStatus == 'completed')
            && (request.resource.data.subStatus != 'completed'
                || (request.resource.data.completionProofs is list
                    && request.resource.data.completionProofs.size() > 0
                    && request.resource.data.completionProofs.size() <= 10))
            && (!('attachments' in request.resource.data)
                || !(request.resource.data.attachments is list)
                || request.resource.data.attachments.size() <= 20)
            && (request.resource.data.subStatus != 'completed'
                || request.resource.data.completedAt == request.time)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'assigneeCompleted', 'reminderSent', 'subStatus',
              'attachments', 'takenToWorkAt', 'takenToWorkBy', 'completedAt',
              'completionComment', 'completionProof', 'completionProofs',
              'completedBy', 'revisionReason', 'revisionReturnedBy',
              'revisionReturnedAt', 'archivedAt', 'archivedBy'
            ]))
        || (request.auth != null
            && isPrivateTaskParticipant(resource.data)
            && resource.data.coCreatorIds is list
            && request.auth.uid in resource.data.coCreatorIds
            && request.resource.data.projectId == resource.data.projectId
            && resource.data.status == 'in-progress'
            && resource.data.subStatus == 'completed'
            && (
              (request.resource.data.status == 'done'
                && request.resource.data.subStatus == 'completed'
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  'status', 'subStatus', 'archivedAt', 'archivedBy',
                  'completedOnTime', 'xpAwarded', 'assigneeCompleted'
                ]))
              || (request.resource.data.status == 'in-progress'
                && request.resource.data.subStatus == 'in_work'
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  'status', 'subStatus', 'takenToWorkAt', 'takenToWorkBy',
                  'completedAt', 'completionComment', 'completionProof',
                  'completionProofs', 'completedBy', 'archivedAt', 'archivedBy',
                  'revisionReason', 'revisionReturnedBy', 'revisionReturnedAt',
                  'wasReturned', 'assigneeCompleted'
                ]))
            ));
    }

    // Коллекция Project Files (подколлекция файлов проекта)
    // Все записи выполняются только сервером через Admin SDK (в обход правил) — клиент может только читать.
    match /projects/{projectId}/files/{fileId} {
      // owner/admin: all files in their org's projects; moderator/employee/reader:
      // only files of projects they can view (allowedProjects). Writes are
      // server-only (api/project-files, which also enforces project access).
      allow read: if isAdmin()
        || hasProjectOrgRole(projectId, ['owner', 'admin'])
        || (request.auth != null && projectBelongsToOrg(projectId, myOrgId()) && canViewProject(projectId));
      allow write: if false;
    }

    // telegramCodes — legacy-инфраструктура старого подключения по коду. Больше
    // не используется (вход и привязка идут через bot deep-link, см.
    // lib/telegram-bot-login.js). Коллекция закрыта полностью (default deny).

    // auditLogs — server-side audit trail для критичных операций организации
    // (`api/org`). Клиент не должен читать или подделывать audit-записи.
    match /auditLogs/{logId} {
      allow read, write: if false;
    }

    // agentNotifications — лента уведомлений ИИ-агента (просрочки, «остался
    // 1 день», «не взял в работу», «задачи созданы из документа»). Пишет
    // ТОЛЬКО сервер (api/agent-monitor, api/agent-chat через Admin SDK).
    // Клиент: читает и помечает прочитанным ТОЛЬКО свои записи (readAt) —
    // подделать, переписать текст или удалить историю нельзя.
    match /agentNotifications/{noteId} {
      // Строгая изоляция организаций: свои записи И только ТЕКУЩЕЙ организации
      // (uid переживает смену орг — без org-проверки уведомления прежней
      // организации «переезжали» за пользователем в новую). Клиентский
      // листенер обязан фильтровать where uid == И where organizationId ==.
      allow get, list: if request.auth != null
        && resource.data.uid == request.auth.uid
        && resource.data.organizationId == myOrgId();
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && resource.data.organizationId == myOrgId()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
      // Удаление — серверное (api/agent-chat delete_notification, Admin SDK).
      allow create, delete: if false;
    }

    // Полный журнал запросов переноса срока. Создание и решение выполняет
    // только api/deadline-change транзакцией через Admin SDK; клиент получает
    // актуальное ожидающее состояние из защищённого поля задачи.
    match /deadlineChangeRequests/{requestId} {
      allow read, write: if false;
    }
  }
}
