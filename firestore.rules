rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Функция: Проверка, что пользователь Админ
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Функция: Проверка, что пользователь не меняет защищенные поля (роль, доступы, организация)
    function notUpdatingRestrictedFields() {
      return (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'allowedProjects', 'organizationId', 'orgRole']));
    }

    // Функция: Самостоятельное присоединение к организации (только с ролью employee)
    function isSelfServiceOrgJoin() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.hasOnly(['organizationId', 'orgRole'])
        && request.resource.data.orgRole == 'employee';
    }

    // Функция: Самостоятельный выход из организации
    function isSelfServiceOrgLeave() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.hasOnly(['organizationId', 'orgRole'])
        && request.resource.data.organizationId == null
        && request.resource.data.orgRole == null;
    }

    // Функция: Проверка, что пользователь ещё не состоит в организации
    function wasNotYetInOrg() {
      return !('organizationId' in resource.data) || resource.data.organizationId == null;
    }

    // Функция: Самостоятельное создание организации (пользователь должен реально быть владельцем целевого документа organizations)
    function isSelfServiceOrgCreate() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.hasOnly(['organizationId', 'orgRole', 'email', 'displayName'])
        && request.resource.data.orgRole == 'owner'
        && wasNotYetInOrg()
        && exists(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId))
        && get(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)).data.ownerId == request.auth.uid;
    }

    // Функция: Тот же сценарий создания организации, но при СОЗДАНИИ документа users/{uid}
    // (set(..., {merge:true}) на несуществующий документ Firestore трактует как create, а не update —
    // без этой функции createOrganization() на "свежем" users-документе полностью обходил бы isSelfServiceOrgCreate()).
    function isSelfServiceOrgCreateAtDocCreation() {
      return request.resource.data.keys().hasOnly(['organizationId', 'orgRole', 'email', 'displayName', 'role'])
        && (!('role' in request.resource.data) || request.resource.data.role == 'reader')
        && request.resource.data.orgRole == 'owner'
        && exists(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId))
        && get(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)).data.ownerId == request.auth.uid;
    }

    // Функция: Проверка прав на проект
    function canViewProject(projectId) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userData.allowedProjects == null || userData.allowedProjects.size() == 0 || projectId in userData.allowedProjects;
    }

    // Функция: Проверка роли пользователя именно в указанной организации
    function hasOrgRole(orgId, roles) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null
        && orgId != null
        && userData.organizationId == orgId
        && userData.orgRole in roles;
    }

    function projectBelongsToOrg(projectId, orgId) {
      return projectId != null
        && orgId != null
        && exists(/databases/$(database)/documents/projects/$(projectId))
        && get(/databases/$(database)/documents/projects/$(projectId)).data.organizationId == orgId;
    }

    // Коллекция Users
    match /users/{userId} {
      // Читать могут все авторизованные (нужно для списков assignee), 
      // но лучше ограничить: каждый себя или Админ всех. 
      // Для простоты пока оставим: Админ или владелец.
      // (ВАЖНО: Для выпадающего списка "assignee" нам нужно, чтобы пользователи могли видеть список коллег.
      // Поэтому разрешим читать список пользователей всем авторизованным)
      allow read: if request.auth != null;
      
      // Создавать профиль может только сам пользователь при регистрации (и роль должна быть 'reader' или отсутствовать),
      // ИЛИ это самостоятельное создание организации на ещё не существующем документе (см. isSelfServiceOrgCreateAtDocCreation).
      allow create: if request.auth != null && request.auth.uid == userId && (
        (!request.resource.data.keys().hasAny(['organizationId', 'orgRole'])
          && (!request.resource.data.keys().hasAll(['role']) || request.resource.data.role == 'reader'))
        || isSelfServiceOrgCreateAtDocCreation()
      );
      
      // Обновлять: Владелец (но БЕЗ смены роли/оргполей, кроме явных сценариев join/leave/create) ИЛИ Админ (все поля)
      allow update: if (request.auth != null && request.auth.uid == userId
                         && (notUpdatingRestrictedFields() || isSelfServiceOrgJoin() || isSelfServiceOrgLeave() || isSelfServiceOrgCreate()))
                    || isAdmin();

      // Удалять: Только Админ
      allow delete: if isAdmin();
    }

    // Функция: Изменение membersCount ровно на ±1 (шаг присоединения/выхода участника)
    function isMemberCountStep() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.hasOnly(['membersCount'])
        && (request.resource.data.membersCount == resource.data.membersCount + 1
            || request.resource.data.membersCount == resource.data.membersCount - 1);
    }

    // Функция: Пользователь — владелец организации (по своему orgRole) или админ организации
    function isOrgOwnerOrAdmin(orgId) {
      return hasOrgRole(orgId, ['owner', 'admin']);
    }

    // Коллекция Organizations
    match /organizations/{orgId} {
      // Читать могут все авторизованные пользователи
      allow read: if request.auth != null;
      // Создать может только тот, кто указывает себя владельцем
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      // Обновлять: владелец организации ИЛИ пользователь с orgRole owner/admin ИЛИ шаг ±1 membersCount (join/leave)
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        isOrgOwnerOrAdmin(orgId) ||
        isMemberCountStep()
      );
      // Удалять: только владелец организации ИЛИ пользователь с orgRole owner/admin
      allow delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        isOrgOwnerOrAdmin(orgId)
      );
    }

    // Коллекция Projects
    match /projects/{projectId} {
      allow read: if isAdmin()
        || hasOrgRole(resource.data.organizationId, ['owner', 'admin'])
        || (request.auth != null && canViewProject(projectId));
      allow create: if isAdmin() || hasOrgRole(request.resource.data.organizationId, ['owner', 'admin']);
      allow update: if isAdmin()
        || (hasOrgRole(resource.data.organizationId, ['owner', 'admin'])
            && request.resource.data.organizationId == resource.data.organizationId);
      allow delete: if isAdmin() || hasOrgRole(resource.data.organizationId, ['owner', 'admin']);
    }

    // Коллекция Tasks
    match /tasks/{taskId} {
      // Чтение: Админ или если есть доступ к проекту (тут сложно проверить проект без лишнего get, 
      // но мы проверим через поле projectId в самой задаче)
      allow read: if isAdmin()
        || hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'moderator'])
        || (request.auth != null && canViewProject(resource.data.projectId));
      
      // Запись: 
      // 1. Админ может всё.
      // 2. Обычный пользователь (Reader) может только ОБНОВЛЯТЬ статус задачи (drag & drop) 
      // и ставить галочку "assigneeCompleted", но НЕ менять название/дедлайн/удалять.
      allow create: if isAdmin()
        || (hasOrgRole(request.resource.data.organizationId, ['owner', 'admin', 'moderator'])
            && projectBelongsToOrg(request.resource.data.projectId, request.resource.data.organizationId));
      allow delete: if isAdmin() || hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'moderator']);
      allow update: if isAdmin()
        || (hasOrgRole(resource.data.organizationId, ['owner', 'admin', 'moderator'])
            && request.resource.data.organizationId == resource.data.organizationId
            && request.resource.data.projectId == resource.data.projectId)
        || (request.auth != null
            && canViewProject(resource.data.projectId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'assigneeCompleted', 'reminderSent', 'subStatus', 'attachments']));
    }

    // Коллекция Project Files (подколлекция файлов проекта)
    // Все записи выполняются только сервером через Admin SDK (в обход правил) — клиент может только читать.
    match /projects/{projectId}/files/{fileId} {
      allow read: if isAdmin() || (request.auth != null && canViewProject(projectId));
      allow write: if false;
    }

    // Коллекция Calendar Events (Новый календарь)
    match /calendar_events/{eventId} {
      // Разрешаем чтение и запись всем авторизованным пользователям
      // Это позволяет видеть общий календарь команды
      allow read, write: if request.auth != null;
    }

    // Коллекция telegramCodes - временные коды для подключения Telegram
    match /telegramCodes/{code} {
      // Пользователь может создать код для себя
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Чтение и удаление - для серверных функций (через API key)
      allow read, delete: if true;
    }
  }
}
